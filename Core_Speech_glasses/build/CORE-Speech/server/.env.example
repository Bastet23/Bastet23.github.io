# Copy to `.env` and fill in your credentials.

# --- General ---
ENVIRONMENT=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# --- Camera ---
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# --- Local LLM via Ollama (no API key, GPU-auto) ---
# Install Ollama (https://ollama.com), then:  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.4
OLLAMA_MAX_TOKENS=512
# -1 = auto (use GPU if available, fall back to CPU). 0 = force CPU.
OLLAMA_NUM_GPU=-1
OLLAMA_KEEP_ALIVE=5m
OLLAMA_REQUEST_TIMEOUT=60

# --- OpenVoice v2 + MeloTTS ---
# Folder containing the unzipped `checkpoints_v2_0417` archive.
OPENVOICE_CHECKPOINTS=models/openvoice_v2
# MeloTTS language: EN, ES, FR, ZH, JP, KR
OPENVOICE_LANGUAGE=EN
# MeloTTS speaker key within the chosen language (must exist in spk2id).
OPENVOICE_SPEAKER_KEY=EN-Default
# Filename (without extension) under base_speakers/ses/ used as the source SE.
OPENVOICE_SOURCE_SE_NAME=en-default
# auto / cpu / cuda
OPENVOICE_DEVICE=auto
# PCM sample rate sent to the ESP32. MeloTTS native is 44.1 kHz; we resample.
OPENVOICE_OUTPUT_SAMPLE_RATE=16000
# Special voice id reserved for "no tone-conversion" (just MeloTTS).
OPENVOICE_DEFAULT_VOICE_ID=default

# --- Vosk (local STT) ---
# Backend-neutral wire format (matches what the ESP32 streams over /ws/emission).
STT_SAMPLE_RATE=16000
# 0.8 s = snappy push-to-talk; bridge flushes on button release so shorter
# utterances still get transcribed. Bump to 1.2-1.5 for higher accuracy when
# you're streaming continuously instead of holding a button.
STT_CHUNK_SECONDS=0.8
# Pick ONE of the following two:
#   * VOSK_MODEL_PATH -- local folder with an unpacked model from
#                        https://alphacephei.com/vosk/models (overrides _NAME).
#   * VOSK_MODEL_NAME -- model id Vosk auto-downloads into ~/.cache/vosk.
# Default: tiny English model (~40 MB). Swap to "vosk-model-en-us-0.22"
# (~1.8 GB) for higher accuracy or e.g. "vosk-model-small-es-0.42" for Spanish.
VOSK_MODEL_PATH=
VOSK_MODEL_NAME=vosk-model-small-en-us-0.15
# BCP-47 hint included in transcript JSON; Vosk is single-language per model.
VOSK_LANGUAGE=en

# --- LSTM ---
LSTM_WINDOW_SIZE=30
LSTM_HIDDEN_SIZE=128
LSTM_NUM_LAYERS=2
LSTM_CONFIDENCE_THRESHOLD=0.75
